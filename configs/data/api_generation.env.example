# Copy this file to api_generation.env and fill real values.
# Example:
#   Copy-Item configs/data/api_generation.env.example configs/data/api_generation.env

DISTILL_API_BASE_URL=https://your-openai-compatible-endpoint/v1
DISTILL_API_KEY=your_api_key
DISTILL_API_MODEL=your_model_name

# Optional fallbacks (used if DISTILL_API_* are empty)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
